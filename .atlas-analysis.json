  "keyFeatures": [
    "Ultra-lightweight: <10MB memory footprint, 99% smaller than alternatives",
    "Lightning fast: 1-second boot time even on 0.6GHz single core",
    "Multi-platform: Single binary for RISC-V, ARM, x86 with Go",
    "Multi-channel: Telegram, Discord, WhatsApp, QQ, DingTalk, LINE, WeCom integration",
    "Multi-provider: OpenAI, Anthropic, Zhipu, Gemini, Ollama, and more",
    "AI tools: Web search, file operations, shell execution, cron scheduling",
    "Security sandbox: Workspace-restricted file and command execution",
    "Heartbeat: Periodic autonomous task execution",
    "Skills system: Custom skill loading and management",
    "MCP support: Model Context Protocol integration"
  ],
  "publicApiSurface": [
    "picoclaw agent - Interactive AI chat",
    "picoclaw gateway - Start multi-channel gateway server",
    "picoclaw onboard - Initialize configuration and workspace",
    "picoclaw cron - Manage scheduled tasks and reminders",
    "picoclaw status - Display system status",
    "picoclaw auth - Manage provider authentication",
    "read_file - Read file contents",
    "write_file - Write files to workspace",
    "list_dir - List directory contents",
    "exec - Execute shell commands",
    "edit_file - Edit files with search/replace",
    "append_file - Append content to files",
    "web_search - Search the web (Brave, Tavily, DuckDuckGo)",
    "message - Send messages to users",
    "cron_add - Schedule tasks with cron expressions",
    "spawn - Create subagent for async tasks",
    "mcp_tool - Execute MCP tools"
  ]
}
